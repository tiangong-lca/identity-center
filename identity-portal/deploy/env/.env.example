# Identity Portal local development environment template.
# From the identity-portal root, copy this file to .env:
#   cp deploy/env/.env.example .env
#
# Values marked "change-me" must be replaced before production use.

# Portal
PORTAL_ORIGIN=http://localhost:3000
AUTH_SECRET=

# Platform database exposed by deploy/docker/docker-compose.dev.yml.
# Container-internal Postgres remains 5432; the host port is intentionally 15432
# to avoid tiangong-lca-next self-hosted Supabase conflicts.
DATABASE_URL=postgres://identity:identity@localhost:15432/identity_platform
PG_ADMIN_URL=postgres://postgres:postgres@localhost:15432/postgres

# Optional KingbaseES profile. Container-internal KES remains 54321; the host port
# is intentionally 15433 to keep localhost:54321 available for LCA Supabase Kong.
KINGBASE_URL=postgres://identity:identity@localhost:15433/identity_platform
KINGBASE_ADMIN_URL=postgres://kingbase:kingbase@localhost:15433/test

# Keycloak
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=company-dev
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_ID=user-portal
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_API_CLIENT_ID=user-portal-admin-api
KEYCLOAK_ADMIN_API_CLIENT_SECRET=

# Keycloak email verification is disabled unless KC_VERIFY_EMAIL=true.
# When enabled in local dev, use Mailpit from docker-compose.dev.yml.
KC_VERIFY_EMAIL=false
KC_SMTP_HOST=localhost
KC_SMTP_PORT=1025

# Redis / BullMQ / rate limiting. Redis is password-protected in dev compose.
REDIS_PASSWORD=identity-dev-redis
REDIS_URL=redis://:identity-dev-redis@localhost:16379

# RabbitMQ
RABBITMQ_URL=amqp://identity:identity@localhost:5672

# Seed admin used by local/e2e workflows.
SEED_ADMIN_EMAIL=admin@identity.local
SEED_ADMIN_PASSWORD=Identity-Admin-2026

# First business application: TianGong LCA self-hosted Supabase.
TIANGONG_LCA_GOTRUE_CALLBACK=http://localhost:54321/auth/v1/callback
TIANGONG_LCA_APP_ORIGIN=http://localhost:8000
TIANGONG_LCA_WEBHOOK_URL=http://localhost:54321/functions/v1/identity_center_webhook
TIANGONG_LCA_WEBHOOK_SECRET=change-me-shared-secret
TIANGONG_LCA_LOGIN_URL=http://localhost:8000/#/user/login

# Security / optional production-only integrations.
PII_ENCRYPTION_KEY=
CAPTCHA_PROVIDER=
CAPTCHA_SECRET=

# Production compose variables. For production, copy this file to
# deploy/env/.env.production and replace every change-me/default secret.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-keycloak-admin-password
