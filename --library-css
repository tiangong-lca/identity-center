<body class="min-h-screen font-sans antialiased">
    <main class="flex items-center justify-center min-h-screen" style="background: var(--color-background);">
      <div class="w-full max-w-[400px] md:max-w-[800px] mx-auto md:flex md:shadow-2 md:rounded-sm overflow-hidden">
        <!-- Left visual panel (hidden on narrow screens) -->
        <div class="hidden md:flex md:flex-col md:justify-center md:items-center md:w-1/2 px-8 py-16" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);">
          <h1 class="text-3xl font-semibold text-center leading-tight" style="color: var(--color-on-primary); text-wrap: balance; word-break: keep-all; overflow-wrap: break-word;">Identity Platform</h1>
          <p class="mt-3 text-base font-normal text-center" style="color: var(--color-on-primary); opacity: 0.85;">统一身份管理平台</p>
        </div>
